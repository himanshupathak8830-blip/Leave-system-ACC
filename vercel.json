{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/server.js"
    },
    {
      "src": "/login",
      "dest": "/server.js"
    },
    {
      "src": "/apply-leave",
      "dest": "/server.js"
    },
    {
      "src": "/leaves",
      "dest": "/server.js"
    },
    {
      "src": "/approve/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/reject/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/email-jobs(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
