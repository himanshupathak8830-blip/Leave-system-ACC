# Local development example. Do not commit your real .env file.
PORT=3000

# Railway MySQL can provide MYSQL_URL, or these individual variables.
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=8588
MYSQLDATABASE=leaveDB

# Required when the admin table is empty.
ADMIN_EMAIL=himanshu.data.acc@gmail.com
ADMIN_PASSWORD=1234

# Required for stable admin login sessions after deploy.
TOKEN_SECRET=generate-a-long-random-secret
TOKEN_TTL_MS=28800000
APP_URL=https://leaves-management-system8-production.up.railway.app
ADMIN_PANEL_URL=https://leaves-management-system8-production.up.railway.app/admin.html

# Admin panel list cleanup. Leave requests older than this many days are removed.
LEAVE_RETENTION_DAYS=7

# Email send timeout for delayed notification jobs.
EMAIL_SEND_TIMEOUT_MS=20000
EMAIL_SEND_DELAY_MS=0
EMAIL_JOB_POLL_INTERVAL_MS=5000
EMAIL_JOB_RETRY_DELAY_MS=60000

# Recommended on Railway Free/Trial/Hobby because SMTP/Gmail is blocked there.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Analytics Career Connect <noreply@your_verified_domain.com>

# Alternative HTTPS provider.
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM=Analytics Career Connect <your_verified_sender@example.com>

# SMTP/Gmail only works locally or on Railway Pro and above.
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_without_spaces
EMAIL_FROM=your_email@gmail.com
LEAVE_NOTIFICATION_EMAIL=your_admin_notification_email@gmail.com
HR_NAME=Faizah Waseem
HR_DEPARTMENT=HR Department
COMPANY_NAME=Analytics Career Connect
COMPANY_LOGO_URL=https://drive.google.com/thumbnail?id=1oqFkpO8Hhv7IEYeKXWq19uubuKeFHCZ9&sz=w800
