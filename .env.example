# Local development example. Do not commit your real .env file.
PORT=3000

TOKEN_SECRET=your_secret_key_here
TOKEN_TTL_MS=28800000

# Google Sheets Integration
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_SERVICE=gmail
EMAIL_FROM=Leave System <your-email@gmail.com>

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_PANEL_URL=http://localhost:3000/admin.html

# Notification Configuration
LEAVE_NOTIFICATION_EMAIL=hr@example.com
HR_NAME=HR Department
COMPANY_NAME=Analytics Career Connect
